# Provider credentials belong in .env files only.
# Do not commit real API keys or auth tokens.
# Preferred private path: .hydra-state/.env
# Compatibility path: .env

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional first-party CLI bridge paths for subscription mode and passthrough.
HYDRA_CLAUDE_BIN=
HYDRA_CODEX_BIN=

# Optional subscription CLI tool/permission defaults.
HYDRA_CLAUDE_PERMISSION_MODE=acceptEdits
HYDRA_CLAUDE_TOOLS=default
HYDRA_CLAUDE_ALLOWED_TOOLS=Bash(hydra native *)
HYDRA_CODEX_SANDBOX=workspace-write
